  <style>
    :root {
      --bg: #FEFEFE;
      --bg-alt: #FFFDE7;
      --fg: #2D2A24;
      --muted: #7A756A;
      --accent: #FFC107;
      --accent-dark: #FFA000;
      --brand-red: #D32F2F;
      --card: #FFFFFF;
      --border: #F0EBD8;
      --success: #2E7D32;
      --shadow-sm: 0 2px 8px rgba(45, 42, 36, 0.06);
      --shadow-md: 0 8px 24px rgba(45, 42, 36, 0.08);
      --shadow-lg: 0 16px 48px rgba(45, 42, 36, 0.12);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg);
      color: var(--fg);
      min-height: 100vh;
      overflow-x: hidden;
    }

    [dir="rtl"] { 
      direction: rtl; 
      text-align: right; 
      font-family: 'IBM Plex Sans Arabic', 'Outfit', sans-serif;
    }
    [dir="rtl"] .rtl-flip { transform: scaleX(-1); }
    [dir="rtl"] .cart-drawer { right: auto; left: 0; transform: translateX(-100%); }
    [dir="rtl"] .cart-drawer.open { transform: translateX(0); }

    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .animate-slide-up {
      animation: slideUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      opacity: 0;
    }

    .stagger-1 { animation-delay: 0.05s; }
    .stagger-2 { animation-delay: 0.1s; }
    .stagger-3 { animation-delay: 0.15s; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }

    .slider-track {
      display: flex;
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .cart-drawer {
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .cart-drawer.open { transform: translateX(0); }

    .menu-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .menu-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
      color: #5b2d00;
      box-shadow: 0 4px 16px rgba(255, 193, 7, 0.3);
      transition: all 0.2s ease;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255, 193, 7, 0.4);
    }
    
    .btn-red {
      background: linear-gradient(135deg, var(--brand-red) 0%, #B71C1C 100%);
      color: white;
      box-shadow: 0 4px 16px rgba(211, 47, 47, 0.3);
    }

    .tab-btn.active {
      background: var(--accent);
      color: #5b2d00;
      box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
    }

    .badge-hot {
      background: linear-gradient(135deg, #FF6B35 0%, var(--brand-red) 100%);
      color: white;
    }
    
    .price-tag {
      background: linear-gradient(135deg, var(--bg-alt) 0%, #FFF8E1 100%);
      border: 1px solid rgba(255, 193, 7, 0.3);
    }

    .qty-btn:hover {
      background: var(--accent);
      color: #5b2d00;
    }

    .hide-scroll::-webkit-scrollbar { display: none; }
    .hide-scroll { -ms-overflow-style: none; scrollbar-width: none; }

    /* Edit Mode Styles */
    .edit-mode-active .menu-card {
      border: 2px dashed var(--accent);
    }
    .edit-mode-active .food-img {
      cursor: pointer;
      opacity: 0.8;
    }
    .edit-mode-active .food-img:hover {
      opacity: 0.6;
      outline: 3px solid var(--brand-red);
    }
    .edit-btn-active {
      background: var(--brand-red) !important;
      color: white !important;
    }
  </style>
