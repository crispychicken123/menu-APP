    // ==================== STATE ====================
    let cart = [];
    let currentLang = "en";
    let currentCategory = "deals";
    let isEditMode = false;

    // ==================== DOM ====================
    const body = document.body;
    const langToggle = document.getElementById("langToggle");
    const langLabel = document.getElementById("langLabel");
    const categoryTabs = document.getElementById("categoryTabs");
    const menuSection = document.getElementById("menuSection");
    const branchesSection = document.getElementById("branchesSection");
    const branchesList = document.getElementById("branchesList");
    const cartBtn = document.getElementById("cartBtn");
    const cartDrawer = document.getElementById("cartDrawer");
    const cartOverlay = document.getElementById("cartOverlay");
    const closeCart = document.getElementById("closeCart");
    const cartItems = document.getElementById("cartItems");
    const emptyCart = document.getElementById("emptyCart");
    const cartSummary = document.getElementById("cartSummary");
    const cartCount = document.getElementById("cartCount");
    const subtotal = document.getElementById("subtotal");
    const totalPrice = document.getElementById("totalPrice");
    const checkoutBtn = document.getElementById("checkoutBtn");
    const floatingOrder = document.getElementById("floatingOrder");
    const floatingText = document.getElementById("floatingText");
    const toastContainer = document.getElementById("toastContainer");
    const editModeBtn = document.getElementById("editModeBtn");

    // ==================== UTILITIES ====================
    function t(key) {
      return currentLang === "ar" ? key + "_ar" : key + "_en";
    }

    function showToast(msg, type = "success") {
      const toast = document.createElement("div");
      toast.className = `px-5 py-3 rounded-xl text-sm font-medium animate-slide-up shadow-lg ${type === "success" ? "bg-[var(--success)] text-white" : "bg-[var(--brand-red)] text-white"}`;
      toast.textContent = msg;
      toastContainer.appendChild(toast);
      setTimeout(() => { toast.style.opacity = "0"; setTimeout(() => toast.remove(), 200); }, 2500);
    }

    // ==================== LANGUAGE ====================
    function updateLang() {
      document.documentElement.lang = currentLang;
      document.documentElement.dir = currentLang === "ar" ? "rtl" : "ltr";
      langLabel.textContent = currentLang === "en" ? "عربي" : "English";
      
      document.querySelectorAll("[data-en]").forEach(el => el.textContent = el.getAttribute(`data-${currentLang}`));
      
      renderCategories();
      renderMenu();
      renderBranches();
    }

    langToggle.addEventListener("click", () => {
      currentLang = currentLang === "en" ? "ar" : "en";
      updateLang();
    });

    // ==================== EDIT MODE ====================
    editModeBtn.addEventListener("click", () => {
      isEditMode = !isEditMode;
      body.classList.toggle("edit-mode-active", isEditMode);
      editModeBtn.classList.toggle("edit-btn-active", isEditMode);
      
      if (isEditMode) {
        showToast("Edit Mode ON: Click an image to change it.", "success");
      } else {
        showToast("Edit Mode OFF", "success");
      }
    });

    function changeItemImage(itemId) {
      if (!isEditMode) return;
      
      const item = menuItems.find(i => i.id === itemId);
      if (!item) return;

      const newUrl = prompt("Enter new image URL:", item.image);
      
      if (newUrl !== null && newUrl.trim() !== "") {
        item.image = newUrl;
        renderMenu();
        showToast("Image updated!");
      }
    }

    // ==================== CATEGORIES ====================
    function renderCategories() {
      categoryTabs.innerHTML = categories.map(c => `
        <button class="tab-btn flex items-center gap-1.5 px-4 py-2.5 rounded-xl bg-white border border-[var(--border)] text-sm font-medium whitespace-nowrap shadow-sm ${currentCategory === c.id ? "active" : ""}" data-cat="${c.id}">
          <span>${c.emoji}</span>
          <span>${c[t("name")]}</span>
        </button>
      `).join("");
    }

    categoryTabs.addEventListener("click", e => {
      const btn = e.target.closest("[data-cat]");
      if (btn) {
        currentCategory = btn.dataset.cat;
        renderCategories();
        if (currentCategory === "branches") {
          menuSection.classList.add("hidden");
          branchesSection.classList.remove("hidden");
          renderBranches();
        } else {
          menuSection.classList.remove("hidden");
          branchesSection.classList.add("hidden");
          renderMenu();
        }
      }
    });

    // ==================== MENU ====================
    function renderMenu() {
      const items = currentCategory === "deals" ? menuItems : menuItems.filter(i => i.category === currentCategory);
      
      menuSection.innerHTML = items.map((item, i) => `
        <article class="menu-card animate-slide-up stagger-${(i % 3) + 1} bg-white rounded-2xl overflow-hidden shadow-md border border-[var(--border)]">
          <div class="flex">
            <div class="w-28 h-28 flex-shrink-0 overflow-hidden relative">
              <img src="${item.image}" alt="${item[t("name")]}" class="food-img w-full h-full object-cover" data-id="${item.id}">
              ${isEditMode ? `<div class="absolute inset-0 bg-black/40 flex items-center justify-center pointer-events-none"><span class="text-white text-xs font-bold bg-black/50 px-2 py-1 rounded">Change</span></div>` : ''}
            </div>
            <div class="flex-1 p-3 flex flex-col justify-between">
              <div>
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-semibold text-base leading-tight">${item[t("name")]}</h3>
                  ${item.badge ? `<span class="badge-${item.badge} px-2 py-0.5 rounded text-[10px] font-bold uppercase">${item.badge === "hot" ? (currentLang === "ar" ? "حار" : "Hot") : (currentLang === "ar" ? "الأفضل" : "Best")}</span>` : ""}
                </div>
                <p class="text-xs text-[var(--muted)] mt-1 line-clamp-2">${item[t("desc")]}</p>
              </div>
              <div class="flex items-center justify-between mt-2">
                <span class="price-tag px-3 py-1 rounded-lg font-bold text-sm">${item.price} AED</span>
                <button class="add-btn btn-primary px-3 py-1.5 rounded-lg text-xs font-semibold" data-id="${item.id}">
                  <span>${currentLang === "ar" ? "أضف" : "Add"}</span>
                </button>
              </div>
            </div>
          </div>
        </article>
      `).join("");
    }

    menuSection.addEventListener("click", e => {
      // Handle Image Change
      const img = e.target.closest(".food-img");
      if (img && isEditMode) {
        e.stopPropagation();
        changeItemImage(parseInt(img.dataset.id));
        return;
      }

      // Handle Add to Cart
      const btn = e.target.closest(".add-btn");
      if (btn && !isEditMode) {
        addToCart(parseInt(btn.dataset.id));
      }
    });

    // ==================== BRANCHES ====================
    function renderBranches() {
      branchesList.innerHTML = branches.map(b => `
        <div class="bg-white rounded-xl p-4 shadow-sm border border-[var(--border)] flex items-center justify-between">
          <div>
            <p class="font-semibold">${b[t("name")]}</p>
            <p class="text-xs text-[var(--muted)]">${b[t("area")]}</p>
          </div>
          <a href="${b.url}" target="_blank" class="btn-red px-4 py-2 rounded-xl text-sm font-semibold shadow-sm hover:shadow-md transition-shadow">
            ${currentLang === "ar" ? "اطلب الآن" : "Order Now"}
          </a>
        </div>
      `).join("");
    }

    // ==================== CART ====================
    function addToCart(id) {
      const item = menuItems.find(i => i.id === id);
      if (!item) return;
      
      const existing = cart.find(c => c.id === id);
      if (existing) existing.qty++;
      else cart.push({ ...item, qty: 1 });
      
      updateCart();
      showToast(currentLang === "ar" ? `تمت إضافة ${item.name_ar}` : `${item.name_en} added`);
    }

    function updateQty(id, delta) {
      const item = cart.find(c => c.id === id);
      if (!item) return;
      item.qty += delta;
      if (item.qty <= 0) cart = cart.filter(c => c.id !== id);
      updateCart();
    }

    function updateCart() {
      const totalItems = cart.reduce((s, i) => s + i.qty, 0);
      const subTotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
      
      cartCount.textContent = totalItems;
      cartCount.classList.toggle("hidden", totalItems === 0);
      
      floatingOrder.classList.toggle("hidden", totalItems === 0);
      floatingOrder.classList.toggle("flex", totalItems > 0);
      floatingText.textContent = `${totalItems} ${currentLang === "ar" ? "عناصر" : "items"} - ${subTotal} AED`;
      
      emptyCart.classList.toggle("hidden", cart.length > 0);
      cartItems.classList.toggle("hidden", cart.length === 0);
      cartSummary.classList.toggle("hidden", cart.length === 0);
      
      cartItems.innerHTML = cart.map(item => `
        <div class="flex gap-3 p-3 bg-[var(--bg-alt)] rounded-xl">
          <img src="${item.image}" class="w-16 h-16 rounded-lg object-cover">
          <div class="flex-1 min-w-0">
            <p class="font-medium text-sm truncate">${item[t("name")]}</p>
            <p class="text-[var(--brand-red)] font-bold text-sm">${item.price} AED</p>
            <div class="flex items-center gap-1 mt-1">
              <button class="qty-btn w-7 h-7 rounded-lg bg-white border border-[var(--border)] flex items-center justify-center text-sm font-bold" data-id="${item.id}" data-action="-">-</button>
              <span class="w-8 text-center text-sm font-semibold">${item.qty}</span>
              <button class="qty-btn w-7 h-7 rounded-lg bg-white border border-[var(--border)] flex items-center justify-center text-sm font-bold" data-id="${item.id}" data-action="+">+</button>
            </div>
          </div>
          <button class="text-[var(--muted)] hover:text-[var(--brand-red)] p-1" data-id="${item.id}" data-action="x">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      `).join("");
      
      subtotal.textContent = `${subTotal} AED`;
      totalPrice.textContent = `${subTotal} AED`;
    }

    cartItems.addEventListener("click", e => {
      const btn = e.target.closest("[data-action]");
      if (!btn) return;
      const id = parseInt(btn.dataset.id);
      const action = btn.dataset.action;
      if (action === "+") updateQty(id, 1);
      else if (action === "-") updateQty(id, -1);
      else if (action === "x") { cart = cart.filter(c => c.id !== id); updateCart(); }
    });

    // ==================== DRAWER ====================
    function openCart() {
      cartDrawer.classList.add("open");
      cartOverlay.style.opacity = "1";
      cartOverlay.style.pointerEvents = "auto";
      document.body.style.overflow = "hidden";
    }

    function closeCartDrawer() {
      cartDrawer.classList.remove("open");
      cartOverlay.style.opacity = "0";
      cartOverlay.style.pointerEvents = "none";
      document.body.style.overflow = "";
    }

    cartBtn.addEventListener("click", openCart);
    floatingOrder.addEventListener("click", openCart);
    closeCart.addEventListener("click", closeCartDrawer);
    cartOverlay.addEventListener("click", closeCartDrawer);

    // ==================== CHECKOUT ====================
    checkoutBtn.addEventListener("click", () => {
      if (cart.length === 0) { showToast(currentLang === "ar" ? "السلة فارغة" : "Cart is empty", "error"); return; }
      
      const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
      let msg = currentLang === "ar" ? "*طلب جديد من Crispy Chicken UAE*\n\n" : "*New Order from Crispy Chicken UAE*\n\n";
      cart.forEach(i => msg += `• ${i[t("name")]} x${i.qty} - ${i.price * i.qty} AED\n`);
      msg += currentLang === "ar" ? `\nالإجمالي: ${total} AED` : `\nTotal: ${total} AED`;
      
      // Updated WhatsApp Number
      window.open(`https://wa.me/971501882206?text=${encodeURIComponent(msg)}`, "_blank");
    });

    // ==================== INIT ====================
    renderCategories();
    renderMenu();
  </script>
</body>
</html>
